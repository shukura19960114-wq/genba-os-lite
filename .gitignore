# === 秘密情報（絶対にコミットしない）===
# 実際の Supabase URL / anon key を入れる .env はGit管理外。.env.example だけ残す。
.env
.env.*
!.env.example
# --dart-define-from-file 用のJSON（秘密値）も除外
dev.json
prod.json

# === コード生成物（build_runner: freezed / json_serializable）===
*.freezed.dart
*.g.dart

# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release
